# MSM Konfiguration — nach .env kopieren und anpassen. .env nie committen!

# Zeitzone für alle Zeitangaben (Routinen-Cron, Warte-Fristen, Wartungsfenster).
TZ=Europe/Berlin

# RCON-Passwort des Minecraft-Servers — wird sowohl im mc-fabric-Container
# gesetzt als auch von MSM zum Verbinden genutzt.
MSM_RCON_PASSWORD=

# Minecraft-Version des Servers. EXAKT die laufende Version pinnen —
# eine höhere Version upgradet die Welt beim Start unumkehrbar!
MC_VERSION=1.21.11

# Pfad der Minecraft-Serverdaten auf dem Host (Bind-Mount).
MC_DATA_PATH=/home/knvt/minecraft/fabric_server

# --- Phase 3: Mod-Verwaltung ---

# Client-Paket-Verzeichnis (mods/, shaderpacks/, resourcepacks/).
MC_CLIENT_PACK_PATH=/home/knvt/minecraft/client-pack

# GID des Host-Users, dem die mods-Verzeichnisse gehören (id -g).
# MSM bekommt diese Gruppe, um Updates schreiben zu können —
# die Verzeichnisse müssen gruppen-beschreibbar sein (chmod g+w).
MC_GID=1000

# Adressen des Minecraft-Containers aus Sicht von MSM.
# Solange mc-fabric nicht im selben Compose-Netz läuft (Phase 2), hier die
# Host-IP eintragen, z. B. 192.168.178.100:25565.
MSM_QUERY_ADDR=mc-fabric:25565
MSM_RCON_ADDR=mc-fabric:25575

# LAN-Adresse, an die das Dashboard gebunden wird (LAN-only!).
# Beispiel: 192.168.178.100 — niemals eine öffentliche Adresse.
MSM_BIND_ADDR=127.0.0.1

# NAS-Mountpoint auf dem Host, dessen Erreichbarkeit geprüft wird (optional).
MSM_NAS_PATH=

# Ping-Ziele für das WAN-Monitoring (Gateway wird automatisch ergänzt).
MSM_PING_TARGETS=1.1.1.1,9.9.9.9

# GID der docker-Gruppe auf dem Host (getent group docker | cut -d: -f3)
DOCKER_GID=988

# --- Phase 2 ---

# Login-Passwort als Argon2id-Hash. WICHTIG: Docker Compose interpretiert
# $ in dieser Datei als Variable — jedes $ im Hash muss als $$ escaped
# werden! Am einfachsten automatisch erzeugen und eintragen:
#   HASH=$(docker compose run --rm --no-deps msm -hash-password 'DEIN_PASSWORT')
#   sed -i "s|^MSM_ADMIN_PASSWORD_HASH=.*|MSM_ADMIN_PASSWORD_HASH=${HASH//$/\$\$}|" .env
# Ohne Wert läuft das Dashboard OHNE Login — nur für Entwicklung akzeptabel!
MSM_ADMIN_PASSWORD_HASH=

# Container, die über das Dashboard gesteuert werden dürfen (Komma-getrennt).
# Alles andere bleibt read-only sichtbar.
MSM_MANAGED_CONTAINERS=mc-fabric

# --- Phase 4: Backups (restic) ---

# Verschlüsselungspasswort des restic-Repos. GEHEIM + zusätzlich im
# Passwort-Manager sichern — ohne Passwort sind die Backups UNLESBAR!
RESTIC_PASSWORD=

# NAS-Mountpoint auf dem Host (systemd-Automount, siehe README). Wird
# doppelt genutzt: Erreichbarkeits-Check im Dashboard + Backup-Ziel
# (Repo liegt unter <Pfad>/restic).
# MSM_NAS_PATH=/mnt/mc-backups   -> oben bei MSM_NAS_PATH eintragen

# Name des Backup-Containers, den MSM startet (Compose-Service).
MSM_BACKUP_CONTAINER=mc-backup

# Host-Verzeichnis für die Reboot-Signaldatei (Phase 4.5). Muss zu dem Pfad
# passen, den deploy/host-watcher/install.sh anlegt und überwacht.
MSM_HOST_SIGNAL_PATH=/home/knvt/minecraft/msm-host

# --- Phase 4.8: Client-Paket zu Dropbox (optional) ---
# Scoped App unter https://www.dropbox.com/developers/apps anlegen
# (Berechtigungen: files.content.write, files.content.read, sharing.write),
# dann einmalig den Refresh-Token holen — Anleitung im README.
# Alle drei GEHEIM behandeln; leer = Feature aus.
MSM_DROPBOX_APP_KEY=
MSM_DROPBOX_APP_SECRET=
MSM_DROPBOX_REFRESH_TOKEN=

# --- Phase 4: Discord-Benachrichtigungen ---

# Discord-Webhook-URL (Channel-Einstellungen → Integrationen → Webhooks).
# GEHEIM behandeln: Wer die URL kennt, kann in den Channel posten.
# Leer = Benachrichtigungen aus.
MSM_DISCORD_WEBHOOK_URL=

# Optional statt der Einzel-URL: mehrere Webhooks mit Event-Filtern als
# JSON-Liste. Filter: "*" = alles, "mods." = Präfix, sonst exakter Typ.
# Ereignistypen: routine.ok, routine.failed, mods.applied, mods.rollback,
# version.new, version.ready
# Beispiel (eine Zeile!):
#   MSM_DISCORD_WEBHOOKS=[{"name":"spieler","url":"https://discord.com/api/webhooks/...","events":["version.","mods.applied"]},{"name":"admin","url":"https://discord.com/api/webhooks/...","events":["*"]}]
MSM_DISCORD_WEBHOOKS=
