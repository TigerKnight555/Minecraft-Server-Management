# MSM Konfiguration — nach .env kopieren und anpassen. .env nie committen!

# RCON-Passwort des Minecraft-Servers — wird sowohl im mc-fabric-Container
# gesetzt als auch von MSM zum Verbinden genutzt.
MSM_RCON_PASSWORD=

# Minecraft-Version des Servers. EXAKT die laufende Version pinnen —
# eine höhere Version upgradet die Welt beim Start unumkehrbar!
MC_VERSION=1.21.11

# Pfad der Minecraft-Serverdaten auf dem Host (Bind-Mount).
MC_DATA_PATH=/home/knvt/minecraft/fabric_server

# Adressen des Minecraft-Containers aus Sicht von MSM.
# Solange mc-fabric nicht im selben Compose-Netz läuft (Phase 2), hier die
# Host-IP eintragen, z. B. 192.168.178.100:25565.
MSM_QUERY_ADDR=mc-fabric:25565
MSM_RCON_ADDR=mc-fabric:25575

# LAN-Adresse, an die das Dashboard gebunden wird (LAN-only!).
# Beispiel: 192.168.178.100 — niemals eine öffentliche Adresse.
MSM_BIND_ADDR=127.0.0.1

# NAS-Mountpoint auf dem Host, dessen Erreichbarkeit geprüft wird (optional).
MSM_NAS_PATH=

# Ping-Ziele für das WAN-Monitoring (Gateway wird automatisch ergänzt).
MSM_PING_TARGETS=1.1.1.1,9.9.9.9

# GID der docker-Gruppe auf dem Host (getent group docker | cut -d: -f3)
DOCKER_GID=988

# --- Phase 2 ---

# Login-Passwort als Argon2id-Hash. WICHTIG: Docker Compose interpretiert
# $ in dieser Datei als Variable — jedes $ im Hash muss als $$ escaped
# werden! Am einfachsten automatisch erzeugen und eintragen:
#   HASH=$(docker compose run --rm --no-deps msm -hash-password 'DEIN_PASSWORT')
#   sed -i "s|^MSM_ADMIN_PASSWORD_HASH=.*|MSM_ADMIN_PASSWORD_HASH=${HASH//$/\$\$}|" .env
# Ohne Wert läuft das Dashboard OHNE Login — nur für Entwicklung akzeptabel!
MSM_ADMIN_PASSWORD_HASH=

# Container, die über das Dashboard gesteuert werden dürfen (Komma-getrennt).
# Alles andere bleibt read-only sichtbar.
MSM_MANAGED_CONTAINERS=mc-fabric
